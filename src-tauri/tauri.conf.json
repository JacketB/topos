{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "topos",
  "version": "1.0.0",
  "identifier": "com.topos.map.app",
  "build": {
    "frontendDist": "../dist/topos/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "topos",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "both"
      }
    },
    "resources": [
      "assets/belarus.pmtiles",
      "assets/belarus_topomap_200k.pmtiles",
      "sidecar-renderer/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}